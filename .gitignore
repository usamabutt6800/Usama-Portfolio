# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.npm

# ── Environment variables — NEVER commit these ────────────────────────────────
.env
.env.local
.env.development
.env.production.local
# NOTE: .env.production IS committed (contains only public VITE_ variables)

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-error.log

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp

# ── Local uploads folder (use Cloudinary in production) ──────────────────────
server/src/uploads/*
!server/src/uploads/.gitkeep